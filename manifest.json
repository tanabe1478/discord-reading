{
  "manifest_version": 3,
  "name": "Discord Chat Reader",
  "version": "0.1.4",
  "description": "Reads newly arrived Discord chat messages aloud in the browser.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "offscreen",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://discord.com/*",
    "https://ptb.discord.com/*",
    "https://canary.discord.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://*.tts.quest/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://discord.com/channels/*",
        "https://ptb.discord.com/channels/*",
        "https://canary.discord.com/channels/*"
      ],
      "js": [
        "content-core.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
    },
    "default_title": "Discord Chat Reader",
    "default_popup": "popup.html"
  },
  "commands": {
    "toggle-reader": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Discord Chat Reader の ON/OFF を切り替える"
    }
  }
}
